# Self-managed portable binaries (bootstrapped by `watch-skill doctor`)
bin/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Environment / secrets
.env
.env.*

# Runtime data (never commit user data)
*.db
*.sqlite3
.watch-skill/

# Test / tool caches
.pytest_cache/
.ruff_cache/
.coverage

# OS noise
Thumbs.db
Desktop.ini
.DS_Store

# Local assistant / workspace artifacts (never part of the product)
PROGRESS.md
CLAUDE.md
.claude/
AGENTS.local.md
*_REPORT.md
*.session.md
issues_export.local.json

# Internal notes (never tracked)
notes.local/
